# =============================================================================
# .env.example — Copy this file to .env and fill in your values.
#
# NEVER commit .env to version control.
# On Render, set these variables in the dashboard instead.
# =============================================================================

# --- Telegram ---
# Your bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (integer). Only this user can operate the bot.
# Find it by messaging @userinfobot on Telegram.
OWNER_ID=123456789

# From https://my.telegram.org — required for Pyrogram MTProto uploads
API_ID=12345678
API_HASH=your_api_hash_here

# A random secret string (min 32 chars) to secure the webhook endpoint.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=generate_a_strong_random_secret_here

# The full public URL of your Render web service (no trailing slash).
# Example: https://your-service-name.onrender.com
WEBHOOK_URL=https://your-service-name.onrender.com

# --- MongoDB ---
# Connection string from MongoDB Atlas (Free Tier recommended).
# Example: mongodb+srv://user:password@cluster.mongodb.net/
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/

# Name of the MongoDB database to use.
MONGO_DB_NAME=telegram_bot
